@model SmartIMS.Web.ViewModels.RolePermissionEditViewModel
@{
    ViewData["Title"] = "權限設定";
    ViewData["ToolbarPageCode"] = "PAGE_ADMIN_PERMISSIONS";
    ViewData["ToolbarActions"] = "edit,find,first,previous,next,last";
    var actionOrder = new[] { "NAVIGATE", "CREATE", "DELETE", "COPY", "EDIT", "CANCEL", "FIND", "PRINT", "FIRST", "PREVIOUS", "NEXT", "LAST" };
    var actionCodes = Model.Pages
        .SelectMany(page => page.Actions)
        .GroupBy(action => action.ActionCode)
        .Select(group => group.First())
        .OrderBy(action =>
        {
            var index = Array.IndexOf(actionOrder, action.ActionCode);
            return index < 0 ? int.MaxValue : index;
        })
        .ToList();
}

<div class="page-title-row">
    <h1>權限設定</h1>
</div>

<div class="win-panel mb-2">
    <form asp-action="Permissions" method="get" class="row g-2 align-items-end compact-form">
        <div class="col-md-4">
            <label class="form-label">組別</label>
            <select name="roleId" class="form-select form-select-sm" onchange="this.form.submit()">
                @foreach (var role in Model.Roles)
                {
                    <option value="@role.RoleId" selected="@(Model.SelectedRoleId == role.RoleId)">
                        @role.RoleName
                    </option>
                }
            </select>
        </div>
        <div class="col-md-8">
            <div class="text-muted small">
                勾選組別可使用的頁面與功能。未支援的功能不會出現在該頁設定中。
            </div>
        </div>
    </form>
</div>

<div class="win-panel">
    @if (Model.SelectedRoleId is null)
    {
        <div class="text-muted">尚未建立可設定的組別。</div>
    }
    else
    {
        <form asp-action="SavePermissions" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="roleId" value="@Model.SelectedRoleId" />
            <div class="table-responsive">
                <table class="table table-sm table-bordered win-table align-middle">
                    <thead>
                        <tr>
                            <th>模組</th>
                            <th>頁面</th>
                            @foreach (var action in actionCodes)
                            {
                                <th class="text-center">@action.ActionName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var permissionPage in Model.Pages)
                        {
                            <tr>
                                <td>@permissionPage.MenuGroup</td>
                                <td>
                                    <div>@permissionPage.PageName</div>
                                    <code class="small">@permissionPage.PageCode</code>
                                </td>
                                @foreach (var action in actionCodes)
                                {
                                    var pageAction = permissionPage.Actions.FirstOrDefault(item => item.ActionCode == action.ActionCode);
                                    <td class="text-center">
                                        @if (pageAction is null)
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                        else
                                        {
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="pageActionIds"
                                                   value="@pageAction.PageActionId"
                                                   title="@pageAction.PermissionCode"
                                                   checked="@Model.SelectedPageActionIds.Contains(pageAction.PageActionId)" />
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">儲存組別權限</button>
        </form>
    }
</div>
